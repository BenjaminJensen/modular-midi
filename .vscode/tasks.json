{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "J-Link: Flash RP2350",
            "type": "shell",
            "command": "JLink.exe", 
            "args": [
                "-device", "RP2350_M33_0",
                "-if", "SWD",
                "-speed", "1500",
                "-autoconnect", "1",
                "-ExitOnError", "1",
                "-CommandFile", "${workspaceFolder}/tools/flash.jlink"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        }
    ]
}